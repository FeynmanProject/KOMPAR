# Salin ke .env.local untuk uji build production di laptop:
#   cp .env.example .env.local
#
# Di Vercel: Project Settings → Environment Variables → Production
# Ganti URL backend Anda (tanpa slash di akhir, tanpa /api).
#
# Tanpa kartu (Hugging Face):
# VITE_API_BASE=https://USERNAME-anime-recommender-api.hf.space
#
# Dengan Render:
# VITE_API_BASE=https://anime-recommender-api.onrender.com

VITE_API_BASE=https://USERNAME-anime-recommender-api.hf.space
